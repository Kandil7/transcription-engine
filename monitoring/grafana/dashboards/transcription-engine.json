{
  "dashboard": {
    "id": null,
    "title": "Transcription Engine Overview",
    "tags": ["transcription", "ai", "monitoring"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "System Overview",
        "type": "row",
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "API Health",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"transcription-api\"}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "options": {
                  "0": {
                    "text": "DOWN",
                    "color": "red"
                  },
                  "1": {
                    "text": "UP",
                    "color": "green"
                  }
                },
                "type": "value"
              }
            ]
          }
        },
        "gridPos": {
          "h": 3,
          "w": 4,
          "x": 0,
          "y": 1
        }
      },
      {
        "id": 3,
        "title": "Active Jobs",
        "type": "stat",
        "targets": [
          {
            "expr": "transcription_active_jobs",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 3,
          "w": 4,
          "x": 4,
          "y": 1
        }
      },
      {
        "id": 4,
        "title": "Jobs Completed (1h)",
        "type": "stat",
        "targets": [
          {
            "expr": "increase(transcription_jobs_completed_total[1h])",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 3,
          "w": 4,
          "x": 8,
          "y": 1
        }
      },
      {
        "id": 5,
        "title": "Jobs Failed (1h)",
        "type": "stat",
        "targets": [
          {
            "expr": "increase(transcription_jobs_failed_total[1h])",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "red",
                  "value": 1
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 3,
          "w": 4,
          "x": 12,
          "y": 1
        }
      },
      {
        "id": 6,
        "title": "GPU Memory Usage",
        "type": "stat",
        "targets": [
          {
            "expr": "(gpu_memory_used_bytes / gpu_memory_total_bytes) * 100",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 70
                },
                {
                  "color": "red",
                  "value": 90
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 3,
          "w": 4,
          "x": 16,
          "y": 1
        }
      },
      {
        "id": 7,
        "title": "Average Job Duration",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(transcription_jobs_processing_duration_seconds_sum[5m]) / rate(transcription_jobs_processing_duration_seconds_count[5m])",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "gridPos": {
          "h": 3,
          "w": 4,
          "x": 20,
          "y": 1
        }
      },
      {
        "id": 8,
        "title": "API Performance",
        "type": "row",
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 4
        }
      },
      {
        "id": 9,
        "title": "API Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"transcription-api\"}[5m])",
            "refId": "A",
            "legendFormat": "Requests/sec"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 5
        }
      },
      {
        "id": 10,
        "title": "API Response Time",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"transcription-api\"}[5m]))",
            "refId": "A",
            "legendFormat": "95th percentile"
          },
          {
            "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"transcription-api\"}[5m]))",
            "refId": "B",
            "legendFormat": "50th percentile"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 5
        }
      },
      {
        "id": 11,
        "title": "System Resources",
        "type": "row",
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 13
        }
      },
      {
        "id": 12,
        "title": "CPU Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "(1 - rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100",
            "refId": "A",
            "legendFormat": "CPU Usage %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 14
        }
      },
      {
        "id": 13,
        "title": "Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
            "refId": "A",
            "legendFormat": "Memory Usage %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 8,
          "y": 14
        }
      },
      {
        "id": 14,
        "title": "Disk Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "(1 - node_filesystem_avail_bytes / node_filesystem_size_bytes) * 100",
            "refId": "A",
            "legendFormat": "Disk Usage %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 16,
          "y": 14
        }
      },
      {
        "id": 15,
        "title": "Job Processing",
        "type": "row",
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 22
        }
      },
      {
        "id": 16,
        "title": "Job Success Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(transcription_jobs_completed_total[5m]) / (rate(transcription_jobs_completed_total[5m]) + rate(transcription_jobs_failed_total[5m])) * 100",
            "refId": "A",
            "legendFormat": "Success Rate %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 23
        }
      },
      {
        "id": 17,
        "title": "Queue Length",
        "type": "graph",
        "targets": [
          {
            "expr": "celery_queue_length",
            "refId": "A",
            "legendFormat": "Queue Length"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 23
        }
      },
      {
        "id": 18,
        "title": "Database & Cache",
        "type": "row",
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 31
        }
      },
      {
        "id": 19,
        "title": "PostgreSQL Connections",
        "type": "graph",
        "targets": [
          {
            "expr": "pg_stat_activity_count",
            "refId": "A",
            "legendFormat": "Active Connections"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 32
        }
      },
      {
        "id": 20,
        "title": "Redis Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "redis_memory_used_bytes / redis_memory_max_bytes * 100",
            "refId": "A",
            "legendFormat": "Redis Memory %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 8,
          "y": 32
        }
      },
      {
        "id": 21,
        "title": "MinIO Storage",
        "type": "graph",
        "targets": [
          {
            "expr": "minio_s3_requests_total",
            "refId": "A",
            "legendFormat": "S3 Requests"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 16,
          "y": 32
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {},
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    },
    "refresh": "30s",
    "schemaVersion": 27,
    "version": 0,
    "links": []
  }
}